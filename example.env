# --- Django ---
DJANGO_SECRET_KEY=change-me-generate-with-make-secret-key
DOMAIN=example.com

# --- Database (local dev matches docker-compose.dev.yml defaults) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/django_template
# Production compose composes DATABASE_URL from these three:
DATABASE_USER=app
DATABASE_PASSWORD=change-me
DATABASE_NAME=app

# --- Cache & Celery ---
CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_PASSWORD=change-me

# --- TLS / proxy ---
LETSENCRYPT_EMAIL=admin@example.com
# htpasswd string for the Traefik dashboard; generate:
#   docker run --rm httpd:alpine htpasswd -nb admin <password>
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$replace$me

# --- Observability ---
SENTRY_DSN=
GRAFANA_PASSWORD=change-me

# --- Deploy (set by CI; only needed for manual compose runs) ---
DOCKER_IMAGE=ghcr.io/your-org/your-repo:latest

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
